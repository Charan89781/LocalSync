rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection: Public read for user profiles, write owned by user
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Businesses collection: Public read, authenticated write
    match /businesses/{businessId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // Business Inquiries: Public create, owner/requester read
    match /businessInquiries/{inquiryId} {
      allow read, write: if true;
    }

    // Rental Spaces collection: Public read, authenticated write
    match /spaces/{spaceId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;

      match /reviews/{reviewId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }

    // Bookings collection: Public read/write for demo/testing
    match /bookings/{bookingId} {
      allow read, write: if true;
    }

    // Marketplace listings: Public read, authenticated create/update
    match /listings/{listingId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // Borrow requests: Public read/write for demo/testing
    match /borrowRequests/{requestId} {
      allow read, write: if true;
    }

    // Community Feed posts: Public read, authenticated create/update
    match /posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;

      match /comments/{commentId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }

    // SOS & Neighborhood Alerts: Public read, authenticated create
    match /alerts/{alertId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }

    // Community Events: Public read, authenticated create
    match /events/{eventId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;

      match /discussions/{discussionId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }

    // Chat Rooms: Authenticated read/write
    match /chatRooms/{roomId} {
      allow read, write: if true;

      match /messages/{messageId} {
        allow read, write: if true;
      }
    }
  }
}
